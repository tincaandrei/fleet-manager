# Environment Variables Configuration
# Copy this file to .env and replace every secret before starting Docker.

################################################################################
# JWT Configuration
################################################################################
JWT_SECRET=replace-with-at-least-32-random-characters

################################################################################
# Admin Bootstrap Configuration
################################################################################
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password

################################################################################
# Database Configuration
################################################################################
AUTH_DB_NAME=auth_deploy
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=replace-with-a-strong-auth-db-password
AUTH_DB_HOST_PORT=5432

FLEET_DB_HOST=fleet-postgres
FLEET_DB_PORT=5432
FLEET_DB_NAME=fleet_deploy
FLEET_DB_USER=fleet_user
FLEET_DB_PASSWORD=replace-with-a-strong-fleet-db-password
FLEET_DB_HOST_PORT=5433

DOCUMENT_DB_HOST=document-postgres
DOCUMENT_DB_PORT=5432
DOCUMENT_DB_NAME=document_deploy
DOCUMENT_DB_USER=document_user
DOCUMENT_DB_PASSWORD=replace-with-a-strong-document-db-password
DOCUMENT_DB_HOST_PORT=5434
DOCUMENT_STORAGE_PATH=/app/document-storage
# Optional local/parser overrides. Docker image sets the Python/script defaults.
# DOCUMENT_PARSER_PYTHON=/opt/document-parser-venv/bin/python
# DOCUMENT_PARSER_SCRIPT_PATH=/app/parser/parse_inspection_pdf.py
# DOCUMENT_PARSER_TIMEOUT_SECONDS=30

################################################################################
# Traefik Configuration
################################################################################
# TRAEFIK_DASHBOARD_USER=admin
# TRAEFIK_DASHBOARD_PASSWORD=admin123

################################################################################
# Service URLs
################################################################################
AUTH_SERVICE_URL=http://auth-service:8080
FLEET_SERVICE_URL=http://fleet-service:8080
DOCUMENT_SERVICE_URL=http://document-service:8080

################################################################################
# ACME / Let's Encrypt (for production)
################################################################################
# ACME_EMAIL=admin@example.com
# ACME_ENTRYPOINT=https

################################################################################
# Logging
################################################################################
# LOG_LEVEL=INFO
# TRAEFIK_LOG_LEVEL=INFO

################################################################################
# CORS Configuration
################################################################################
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# CORS_ALLOWED_HEADERS=Authorization,Content-Type
# CORS_MAX_AGE=100

################################################################################
# Rate Limiting
################################################################################
# RATE_LIMIT_AVERAGE=100
# RATE_LIMIT_BURST=50
# RATE_LIMIT_PERIOD=60s
