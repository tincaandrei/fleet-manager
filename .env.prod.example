# Copy this file to .env.prod and replace every placeholder before deployment.
# Do not commit .env.prod.

# Initial IP deployment: use http://YOUR_PUBLIC_IP.
# Domain deployment: use https://example.com and set APP_HOST below.
FRONTEND_URL=http://203.0.113.10
ALLOWED_ORIGINS=http://203.0.113.10
VITE_API_BASE_URL=
APP_HOST=example.com
ACME_EMAIL=admin@example.com

# Use one random value of at least 32 characters for every JWT-validating service.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters

AUTH_DB_NAME=auth_deploy
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=replace-with-a-strong-auth-db-password

FLEET_DB_NAME=fleet_deploy
FLEET_DB_USER=fleet_user
FLEET_DB_PASSWORD=replace-with-a-strong-fleet-db-password

DOCUMENT_DB_NAME=document_deploy
DOCUMENT_DB_USER=document_user
DOCUMENT_DB_PASSWORD=replace-with-a-strong-document-db-password

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
INVITATION_EXPIRY_HOURS=24

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-username
MAIL_PASSWORD=replace-with-smtp-password
MAIL_FROM=noreply@example.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT=60s
OPENAI_MAX_OUTPUT_TOKENS=1500
OPENAI_TEMPERATURE=0

RABBITMQ_DEFAULT_USER=doccufleet
RABBITMQ_DEFAULT_PASS=replace-with-a-strong-rabbitmq-password

# Keep these absolute paths inside their respective containers.
PROFILE_IMAGE_STORAGE_PATH=/app/profile-images
VEHICLE_IMAGE_STORAGE_PATH=/app/vehicle-images
DOCUMENT_STORAGE_PATH=/app/document-storage
DOCUMENT_OCR_LANGUAGE=ron+eng
DOCUMENT_OCR_DPI=300
